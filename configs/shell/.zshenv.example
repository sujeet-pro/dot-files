########################################
# ~/.zshenv - Environment variables for dotfiles setup
#
# Copy this file to ~/.zshenv and fill in your actual values:
#   cp .zshenv.example ~/.zshenv
#
# This file is sourced by zsh before .zshrc and is used by
# Ansible templates to generate git and SSH configs.
#
# NEVER commit ~/.zshenv — it contains personal data and secrets.
########################################

# --- mise shims (makes mise-managed tools available to GUI apps) ---
export PATH="$HOME/.local/share/mise/shims:$PATH"

# --- Default editor & visual ---
export EDITOR="zed --wait"
export VISUAL="zed --wait"

# --- Git Config ---
export GIT_USER_NAME="Your Name"
export GIT_PERSONAL_EMAIL="you@example.com"
export GIT_WORK_EMAIL="you@company.com"

# --- Git Work Orgs (comma-separated, for remote URL-based config matching) ---
# These ensure work git config applies even for repos cloned outside ~/work/
export GIT_WORK_GITHUB_ORGS="Quince-Engineering"
export GIT_WORK_BITBUCKET_ORGS="lastbrand"

# --- SSH Key Filenames (just the filename, not the full path) ---
export SSH_PERSONAL_KEY="id_ed25519_personal"
export SSH_WORK_KEY="id_ed25519_work"

# --- API Tokens (optional — add as needed) ---
# export ANTHROPIC_API_KEY=""
# export OPENAI_API_KEY=""
# export GEMINI_API_KEY=""

# === GitHub ===
# export GITHUB_PAT=""

# === NPM ===
# export NPM_TOKEN=""

# --- AWS (optional) ---
# export AWS_DEFAULT_REGION="ap-south-1"

# === Confluence MCP (mcp-atlassian) ===
# export CONFLUENCE_URL=""
# export CONFLUENCE_USERNAME=""
# export CONFLUENCE_API_TOKEN=""

# === Bitbucket MCP (bitbucket-mcp) ===
# export BITBUCKET_URL="https://api.bitbucket.org/2.0"
# export BITBUCKET_USERNAME=""
# export BITBUCKET_WORKSPACE=""
# export BITBUCKET_TOKEN=""

# === Google Drive MCP (google-drive-mcp) ===
# export GOOGLE_MCP_CLIENT_ID=""
# export GOOGLE_MCP_CLIENT_SECRET=""
# export GOOGLE_DRIVE_OAUTH_CREDENTIALS="$HOME/.config/google-drive-mcp/gcp-oauth.keys.json"

# --- Statsig (optional) ---
# export STATSIG_CONSOLE_API_KEY=""

# --- Claude Code Configuration ---
# export CLAUDE_CODE_MAX_OUTPUT_TOKENS=64000
# export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# --- Datadog (optional) ---
# export DATADOG_APP_KEY=""
# export DATADOG_API_KEY=""
# export DATADOG_KEY_ID=""
