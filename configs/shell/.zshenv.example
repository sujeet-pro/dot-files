########################################
# ~/.zshenv - Environment variables for dotfiles setup
#
# Copy this file to ~/.zshenv and fill in your actual values:
#   cp .zshenv.example ~/.zshenv
#
# This file is sourced by zsh before .zshrc and is used by
# Ansible templates to generate git and SSH configs.
#
# NEVER commit ~/.zshenv — it contains personal data and secrets.
########################################

# --- Git Config ---
export GIT_USER_NAME="Your Name"
export GIT_PERSONAL_EMAIL="you@example.com"
export GIT_WORK_EMAIL="you@company.com"

# --- SSH Key Filenames (just the filename, not the full path) ---
export SSH_PERSONAL_KEY="id_ed25519_personal"
export SSH_WORK_KEY="id_ed25519_work"

# --- API Tokens (optional — add as needed) ---
# export ANTHROPIC_API_KEY=""
# export OPENAI_API_KEY=""
# export GEMINI_API_KEY=""

# --- AWS (optional) ---
# export AWS_DEFAULT_REGION="ap-south-1"

# --- Confluence (optional) ---
# export CONFLUENCE_BASE_URL=""
# export CONFLUENCE_EMAIL=""
# export CONFLUENCE_API_TOKEN=""
