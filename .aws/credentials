# AWS Credentials
# Default is aliased to: integ (change to integ|prod as needed)
# To switch default, update the keys below to match the desired profile

[default]
# Currently pointing to: dev
aws_access_key_id = YOUR_DEV_ACCESS_KEY_ID
aws_secret_access_key = YOUR_DEV_ACCESS_KEY
aws_session_token = YOUR_DEV_SESSION_TOKEN

[dev]
aws_access_key_id = YOUR_DEV_ACCESS_KEY_ID
aws_secret_access_key = YOUR_DEV_ACCESS_KEY
aws_session_token = YOUR_DEV_SESSION_TOKEN

[integ]
aws_access_key_id = YOUR_INTEG_ACCESS_KEY_ID
aws_secret_access_key = YOUR_INTEG_ACCESS_KEY
aws_session_token = YOUR_INTEG_SESSION_TOKEN

[prod]
aws_access_key_id = YOUR_PROD_ACCESS_KEY_ID
aws_secret_access_key = YOUR_PROD_ACCESS_KEY
aws_session_token = YOUR_PROD_SESSION_TOKEN