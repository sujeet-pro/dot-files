# ~/.ssh/config — Managed by Ansible
# Do not edit directly. Update roles/ssh/templates/ssh_config.j2 and re-run the playbook.

# --- Colima (container runtime) ---
Include {{ home_dir }}/.colima/ssh_config

# --- GitHub ---
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/{{ ssh_personal_key }}

# --- Bitbucket ---
Host bitbucket.org
  HostName bitbucket.org
  User git
  IdentityFile ~/.ssh/{{ ssh_work_key }}

# --- Personal hosts (EC2, etc.) ---
Include ~/.ssh/config.local
