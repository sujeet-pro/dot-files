########################################
# ~/.gitconfig - Global Git config
#
# This file is managed by Ansible. Do not edit directly.
# To change, update roles/git/templates/gitconfig.j2 and re-run the playbook.
#
# Directory conventions:
#   - All work repos under:     ~/work/
#   - All personal repos under: ~/personal/
########################################

########################################
# 1. Base identity (common)
########################################

[user]
    name = {{ git_user_name }}
    email = {{ git_personal_email }}

########################################
# 2. Default branch name for new repos
########################################

[init]
    defaultBranch = main

########################################
# 3. Push behavior (common)
########################################

[push]
    autoSetupRemote = true
    default = current

########################################
# 4. Pull behavior (common)
########################################

[pull]
    rebase = false
    ff = only

########################################
# 5. Core behavior (common)
########################################

[core]
    filemode = false
    pager = delta
    hooksPath = ~/.git-hooks

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    hyperlinks = true

[merge]
    ff = only
    conflictstyle = zdiff3

[diff]
    colorMoved = default

########################################
# 6. Colors & pretty output (common)
########################################

[color]
    ui = auto

[log]
    decorate = auto

########################################
# 7. Aliases (common)
########################################

[alias]
    co = checkout
    br = branch
    st = status -sb
    ci = commit
    lg = log --oneline --graph --decorate --all
    ll = log --oneline --decorate --graph --all --date=relative
    dft = "!f() { GIT_EXTERNAL_DIFF=difft git diff \"$@\"; }; f"

########################################
# 8. Conditional includes
#    - Directory-based: for repos under ~/work/ and ~/personal/
#    - Remote URL-based: for work repos cloned outside ~/work/
########################################

# --- Directory-based includes ---

[includeIf "gitdir:~/work/"]
    path = ~/.config/git-configs/work.gitconfig

[includeIf "gitdir:~/personal/"]
    path = ~/.config/git-configs/personal.gitconfig

# --- Remote URL-based includes (GitHub orgs) ---
{% for org in git_work_github_orgs.split(',') | map('trim') | select %}

[includeIf "hasconfig:remote.*.url:git@github.com:{{ org }}/**"]
    path = ~/.config/git-configs/work.gitconfig

[includeIf "hasconfig:remote.*.url:https://github.com/{{ org }}/**"]
    path = ~/.config/git-configs/work.gitconfig
{% endfor %}

# --- Remote URL-based includes (Bitbucket orgs) ---
{% for org in git_work_bitbucket_orgs.split(',') | map('trim') | select %}

[includeIf "hasconfig:remote.*.url:git@bitbucket.org:{{ org }}/**"]
    path = ~/.config/git-configs/work.gitconfig

[includeIf "hasconfig:remote.*.url:https://bitbucket.org/{{ org }}/**"]
    path = ~/.config/git-configs/work.gitconfig
{% endfor %}

########################################
# End of ~/.gitconfig
########################################
